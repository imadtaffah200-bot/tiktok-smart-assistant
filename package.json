{
  "name": "tiktok-smart-assistant",
  "version": "1.0.0",
  "description": "AI-powered TikTok content creation and analytics assistant",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install",
    "start": "node server/index.js"
  },
  "keywords": [
    "tiktok",
    "ai",
    "content-creation",
    "analytics"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "openai": "^4.20.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
